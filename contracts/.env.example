# Network RPC URLs
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org

# Deployer Private Key (DO NOT COMMIT THE REAL .env FILE!)
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# GoodDollar G$ Token Address
# Alfajores Testnet: 0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
# Celo Mainnet: 0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A
GTOKEN_ADDRESS=0x62B8B11039FcfE5aB0C56E502b1C372A3d2a9c7A

# UBI Pool Address (receives 60% of slashed funds)
# For testnet: can use your own wallet address
# For mainnet: use GoodDollar's official UBI pool
UBI_POOL_ADDRESS=your_UBI_wallet_address_here

# Reward Treasury Address (holds G$ tokens for rewards)
# This wallet must:
# 1. Hold G$ tokens
# 2. Approve the staking contract to spend G$ tokens
REWARD_TREASURY_ADDRESS=your_wallet_address_here

# Verifier Address (backend service wallet)
# This is the wallet that will record workouts/quizzes on-chain
# Keep the private key secure in your backend!
VERIFIER_ADDRESS=your_backend_wallet_address_here

# Optional: CeloScan API Key for contract verification
# Get from: https://celoscan.io/myapikey
CELOSCAN_API_KEY=your_celoscan_api_key_here

# NOTE: For testnet, you can use the SAME wallet address for:
# - UBI_POOL_ADDRESS
# - REWARD_TREASURY_ADDRESS  
# - VERIFIER_ADDRESS
# Just make sure that wallet has testnet CELO and G$ tokens!
